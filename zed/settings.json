// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "git_panel": {
    "dock": "left"
  },
  "outline_panel": {
    "dock": "left"
  },
  "agent": {
    "dock": "right",
    "favorite_models": [],
    "model_parameters": []
  },
  "project_panel": {
    "dock": "left"
  },
  "vertical_scroll_margin": 5.0,
  "icon_theme": "Catppuccin Frappé",
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "session": {
    "trust_all_worktrees": true,
  },
  "vim_mode": true,
  "terminal": {
    "font_size": 16.0,
    "font_family": "Comic Mono",
    "font_fallbacks": ["Hack Nerd Font Mono"],
  },
  "git": {
    "inline_blame": {
      "enabled": false,
    },
  },
  "base_keymap": "VSCode",
  "gutter": {
    "line_numbers": true,
  },
  "autosave": {
    "after_delay": {
      "milliseconds": 1000,
    },
  },
  "buffer_font_family": "Comic Mono",
  "semantic_tokens": "full",
  "wrap_guides": [100],
  "soft_wrap": "editor_width",
  "agent_servers": {
    "cursor": {
      "type": "registry"
    },
    "claude-acp": {
      "type": "registry",
    },
  },
  "ui_font_size": 16,
  "agent_buffer_font_size": 14.0,
  "buffer_font_size": 16.0,
  "theme": {
    "mode": "system",
    "light": "One Light",
    "dark": "Catppuccin Mocha (Blur) [Heavy]",
  },
  "edit_predictions": {
    "provider": "zed",
  },
  "languages": {
    "Python": {
      "code_actions_on_format": {
        "source.organizeImports.ruff": true,
      },
      "formatter": {
        "language_server": {
          "name": "ruff",
        },
      },
    },
  },
}
