[core]
    pager = delta

[interactive]
    diffFilter = delta --color-only

[delta]
    navigate = true
    dark = true          # prefer this over light = false — more explicit
    side-by-side = false
    line-numbers = true
[merge]
    conflictstyle = diff3
[diff]
    colorMoved = default
[user]
	name = Raja Haseeb
	email = rajahaseeb147@gmail.com
[credential]
	helper = store
# Conditional configs
[includeIf "gitdir:~/Developer/work/"]
    path = ~/.gitconfig-work

[includeIf "gitdir:~/Developer/personal/"]
    path = ~/.gitconfig-personal

[column]
	ui = auto
[branch]
	sort = -committerdate
[rerere]
	enabled = true
[init]
	defaultBranch = main
[push]
    default = simple
    autoForceWithLease = true
[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
[fetch]
	prune = true
